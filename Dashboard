  <div class="modal" style="max-width:800px">
    <div class="modal-header">
      <div class="modal-title" id="msv-title">Site Details</div>
      <button class="modal-close" onclick="closeModal('modal-site-view')">×</button>
    </div>
    <div class="grid-2" style="margin-bottom:16px">
      <div>
        <div class="form-label">Category</div>
        <div id="msv-cat" style="margin-top:4px"></div>
