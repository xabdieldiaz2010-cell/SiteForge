      <button class="btn btn-primary btn-sm" id="msv-preview-btn">👁️ Preview</button>
      <button class="btn btn-secondary btn-sm" id="msv-copy-btn">📋 Copy Code</button>
      <button class="btn btn-gold btn-sm" id="msv-list-btn">📋 List for Sale</button>
      <button class="btn btn-danger btn-sm" id="msv-delete-btn">🗑️ Delete</button>
    </div>
  </div>
</div>

<!-- TOASTS -->
<div class="toast-container" id="toastContainer"></div>

<script>
// ============================================================
// DATA LAYER — localStorage
// ============================================================
const DB = {
  get(key) { try { return JSON.parse(localStorage.getItem('sf_' + key)) || []; } catch { return []; } },
  set(key, val) { localStorage.setItem('sf_' + key, JSON.stringify(val)); },
  getOne(key) { try { return JSON.parse(localStorage.getItem('sf_' + key)) || {}; } catch { return {}; } },
  setOne(key, val) { localStorage.setItem('sf_' + key, JSON.stringify(val)); }
};

const getData = () => ({
  sites: DB.get('sites'),
  listings: DB.get('listings'),
  leads: DB.get('leads'),
  deals: DB.get('deals'),
  settings: DB.getOne('settings')
});

// ============================================================
// NAVIGATION
// ============================================================
let currentPage = 'dashboard';
function navigate(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + page)?.classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => {
    if (n.getAttribute('onclick')?.includes("'" + page + "'")) n.classList.add('active');
  });
  currentPage = page;
  refreshPage(page);
}

function refreshPage(page) {
  if (page === 'dashboard') renderDashboard();
  if (page === 'sites') renderSites();
  if (page === 'marketplace') renderMarketplace();
  if (page === 'listings') renderListings();
  if (page === 'leads') renderLeads();
  if (page === 'deals') renderDeals();
  if (page === 'analytics') renderAnalytics();
  if (page === 'vault') renderVault();
  if (page === 'settings') loadSettings();
}

// ============================================================
// TOAST
// ============================================================
function toast(msg, type='info') {
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `<span>${msg}</span>`;
  document.getElementById('toastContainer').appendChild(el);
  setTimeout(() => el.remove(), 3500);
}

// ============================================================
// DASHBOARD
// ============================================================
function renderDashboard() {
  const d = getData();
  document.getElementById('stat-sites').textContent = d.sites.length;
  document.getElementById('stat-listings').textContent = d.listings.length;
  const totalVal = d.sites.reduce((s,x)=>s+(+x.value||0),0);
  document.getElementById('stat-value').textContent = '$' + totalVal.toLocaleString();
  document.getElementById('stat-leads').textContent = d.leads.length;

  // Activity
  const feed = document.getElementById('activity-feed');
  const allActivity = [
    ...d.sites.map(s => ({ text: `Site <b>${s.name}</b> created`, time: s.createdAt })),
    ...d.listings.map(l => ({ text: `<b>${l.siteName}</b> listed for $${(+l.price).toLocaleString()}`, time: l.createdAt })),
    ...d.leads.map(l => ({ text: `New lead: <b>${l.name}</b>`, time: l.createdAt })),
    ...d.deals.map(dl => ({ text: `Deal: <b>${dl.site}</b> → ${dl.buyer}`, time: dl.createdAt }))
  ].sort((a,b) => new Date(b.time)-new Date(a.time)).slice(0,6);

  if (!allActivity.length) {
    feed.innerHTML = '<div style="text-align:center;color:var(--muted);padding:20px;font-size:13px">No activity yet. Build your first site!</div>';
  } else {
    feed.innerHTML = allActivity.map(a => `
      <div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)">
        <div style="width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0"></div>
        <div style="font-size:12px;flex:1">${a.text}</div>
        <div style="font-size:11px;color:var(--muted)">${fmtDate(a.time)}</div>
      </div>
    `).join('');
  }
}

// ============================================================
// AI BUILDER
// ============================================================
let generatedHTML = '';
let currentSiteId = null;

async function generateSite() {
  const prompt = document.getElementById('sitePrompt').value.trim();
  const name = document.getElementById('siteName').value.trim() || 'Untitled Site';
  if (!prompt) { toast('Please describe your website first.', 'error'); return; }

  const btn = document.getElementById('generateBtn');
  const status = document.getElementById('aiStatus');
  btn.disabled = true;
  btn.innerHTML = '⏳ Generating…';
  status.classList.add('visible');
  document.getElementById('aiStatusText').textContent = 'Claude is generating your website…';
  document.getElementById('previewPlaceholder').style.display = 'none';

  const systemPrompt = `You are an expert web developer. Generate a complete, self-contained, beautiful, single-file HTML website based on the user's description.

REQUIREMENTS:
- Complete HTML document with <!DOCTYPE html> and all CSS/JS inline
- Professional, modern design — visually stunning
- Responsive and mobile-friendly
- Use Google Fonts (load via <link> tag)
- Include realistic placeholder content
- Dark or light theme based on context
- Add subtle animations and hover effects
- Include ALL sections the user asks for
- Make it look like it was built by a $15,000 agency
- Do NOT use external images (use CSS gradients, shapes, emoji instead)
- Output ONLY the complete HTML code, nothing else, no explanations`;

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 8000,
        system: systemPrompt,
        messages: [{ role: 'user', content: `Create a website for: ${name}\n\nDescription: ${prompt}` }]
      })
    });
    const data = await res.json();
    generatedHTML = data.content?.[0]?.text || '';

    if (!generatedHTML || generatedHTML.includes('error')) {
      toast('Generation failed. Check your connection.', 'error');
    } else {
      // Show preview
      const frame = document.getElementById('previewFrame');
      frame.style.display = 'block';
      frame.srcdoc = generatedHTML;
      document.getElementById('previewUrl').textContent = name.toLowerCase().replace(/\s+/g,'-') + '.siteforge.io';
      document.getElementById('fullPreviewBtn').style.display = 'block';
      document.getElementById('saveGeneratedBtn').style.display = 'flex';

      // Show code
      const codePanel = document.getElementById('generatedCodePanel');
      codePanel.style.display = 'block';
      document.getElementById('codePreview').textContent = generatedHTML.substring(0, 1000) + '\n\n… (full code saved when you click Save)';

      document.getElementById('aiStatusText').textContent = '✅ Website generated successfully!';
      toast('Website generated! Click "Save to Portfolio" to keep it.', 'success');
    }
  } catch(e) {
    toast('Error: ' + e.message, 'error');
    document.getElementById('aiStatusText').textContent = '❌ Generation failed.';
  }

  btn.disabled = false;
  btn.innerHTML = '⚡ Generate with AI';
}

function saveGeneratedSite() {
  const name = document.getElementById('siteName').value.trim() || 'Untitled Site';
  const cat = document.getElementById('siteCategory').value;
  const val = document.getElementById('siteValue').value || '0';
  if (!generatedHTML) { toast('Nothing to save yet.', 'error'); return; }

  const site = {
    id: Date.now().toString(),
    name, category: cat, value: +val,
    status: 'draft',
    html: generatedHTML,
    prompt: document.getElementById('sitePrompt').value,
    createdAt: new Date().toISOString()
  };
  const sites = DB.get('sites');
  sites.push(site);
  DB.set('sites', sites);
  addActivity(`Site <b>${name}</b> saved to portfolio`);
  toast(`"${name}" saved to portfolio!`, 'success');
  document.getElementById('saveGeneratedBtn').style.display = 'none';
  renderDashboard();
}

function clearBuilder() {
  document.getElementById('sitePrompt').value = '';
  document.getElementById('siteName').value = '';
  document.getElementById('siteValue').value = '';
  generatedHTML = '';
  document.getElementById('previewFrame').style.display = 'none';
  document.getElementById('previewPlaceholder').style.display = 'flex';
  document.getElementById('generatedCodePanel').style.display = 'none';
  document.getElementById('aiStatus').classList.remove('visible');
  document.getElementById('saveGeneratedBtn').style.display = 'none';
  document.getElementById('previewUrl').textContent = 'about:blank — generate a site to preview it';
  document.getElementById('fullPreviewBtn').style.display = 'none';
}

function copyCode() {
  if (!generatedHTML) return;
  navigator.clipboard.writeText(generatedHTML);
  toast('Code copied!', 'success');
}

function openFullPreview() {
  const w = window.open('', '_blank');
  w.document.write(generatedHTML);
  w.document.close();
}

// ============================================================
// MY SITES
// ============================================================
let siteFilter = 'all';
function filterSites(f, el) {
  siteFilter = f;
  document.querySelectorAll('.tabs .tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  renderSites();
}

function renderSites() {
  const sites = DB.get('sites');
  const filtered = siteFilter === 'all' ? sites : sites.filter(s => s.status === siteFilter);
  const grid = document.getElementById('siteGrid');
  if (!filtered.length) {
    grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1">
      <div class="icon">🌐</div>
      <h3>No sites${siteFilter !== 'all' ? ' in this filter' : ''}</h3>
      <p>Use the AI Builder to generate a website.</p>
      <button class="btn btn-primary" onclick="navigate('builder')">⚡ Build with AI</button>
    </div>`;
    return;
  }
  grid.innerHTML = filtered.map(s => `
    <div class="site-card" onclick="viewSite('${s.id}')">
      <div class="site-thumb">
        <div class="site-thumb-placeholder">
          <div class="icon">🌐</div>
          <div style="font-size:11px">${s.category}</div>
        </div>
      </div>
      <div class="site-info">
        <div class="site-name">${s.name}</div>
        <div class="site-url">${s.name.toLowerCase().replace(/\s+/g,'-')}.siteforge.io</div>
        <div class="site-meta">
          <span class="site-status ${s.status}">${s.status}</span>
          <div style="font-size:13px;color:var(--gold);font-weight:700">${s.value ? '$'+Number(s.value).toLocaleString() : '—'}</div>
        </div>
        <div style="margin-top:10px;display:flex;gap:6px" onclick="event.stopPropagation()">
          <button class="btn btn-sm btn-secondary" onclick="previewSite('${s.id}')">👁️</button>
          <button class="btn btn-sm btn-secondary" onclick="changeSiteStatus('${s.id}','live')">🟢</button>
          <button class="btn btn-sm btn-gold" onclick="quickList('${s.id}')">💰 List</button>
          <button class="btn btn-sm btn-danger" onclick="deleteSite('${s.id}')">🗑️</button>
        </div>
      </div>
    </div>
  `).join('');
}

function viewSite(id) {
  const sites = DB.get('sites');
  const s = sites.find(x => x.id === id);
  if (!s) return;
  document.getElementById('msv-title').textContent = s.name;
  document.getElementById('msv-cat').innerHTML = `<span class="badge badge-purple">${s.category}</span>`;
  document.getElementById('msv-val').textContent = s.value ? '$'+Number(s.value).toLocaleString() : '—';
  document.getElementById('msv-code').textContent = (s.html || 'No code stored.').substring(0, 2000) + (s.html?.length > 2000 ? '\n…truncated for display' : '');
  document.getElementById('msv-preview-btn').onclick = () => previewSite(id);
  document.getElementById('msv-copy-btn').onclick = () => { navigator.clipboard.writeText(s.html||''); toast('Copied!','success'); };
  document.getElementById('msv-list-btn').onclick = () => { closeModal('modal-site-view'); quickList(id); };
  document.getElementById('msv-delete-btn').onclick = () => { deleteSite(id); closeModal('modal-site-view'); };
  openModal('modal-site-view');
}

function previewSite(id) {
  const sites = DB.get('sites');
  const s = sites.find(x => x.id === id);
  if (!s?.html) { toast('No HTML code for this site.', 'error'); return; }
  const w = window.open('', '_blank');
  w.document.write(s.html);
  w.document.close();
}

function changeSiteStatus(id, status) {
  const sites = DB.get('sites');
  const i = sites.findIndex(s => s.id === id);
  if (i >= 0) { sites[i].status = status; DB.set('sites', sites); renderSites(); toast('Status updated.', 'success'); }
}

function deleteSite(id) {
  if (!confirm('Delete this site? This cannot be undone.')) return;
  const sites = DB.get('sites').filter(s => s.id !== id);
  DB.set('sites', sites);
  renderSites();
  renderDashboard();
  toast('Site deleted.', 'info');
}

function quickList(id) {
  const sites = DB.get('sites');
  const s = sites.find(x => x.id === id);
  if (!s) return;
  document.getElementById('ml-price').value = s.value || '';
  populateSiteSelect(id);
  openModal('modal-list');
}

// ============================================================
// LISTINGS
// ============================================================
function openListSiteModal() {
  populateSiteSelect();
  openModal('modal-list');
}

function populateSiteSelect(defaultId) {
  const sites = DB.get('sites');
  const sel = document.getElementById('ml-site');
  sel.innerHTML = sites.length
    ? sites.map(s => `<option value="${s.id}" ${s.id===defaultId?'selected':''}>${s.name}</option>`).join('')
    : '<option value="">No sites — build one first</option>';
}

function submitListing() {
  const siteId = document.getElementById('ml-site').value;
  const price = document.getElementById('ml-price').value;
  if (!siteId || !price) { toast('Please fill required fields.', 'error'); return; }
  const sites = DB.get('sites');
  const site = sites.find(s => s.id === siteId);
  const listing = {
    id: Date.now().toString(),
    siteId, siteName: site?.name || 'Unknown',
    category: site?.category || 'Other',
    price: +price,
    revenue: +document.getElementById('ml-revenue').value || 0,
    traffic: +document.getElementById('ml-traffic').value || 0,
    desc: document.getElementById('ml-desc').value,
    tags: document.getElementById('ml-tags').value.split(',').map(t=>t.trim()).filter(Boolean),
    createdAt: new Date().toISOString()
  };
  const listings = DB.get('listings');
  listings.push(listing);
  DB.set('listings', listings);

  // Update site status
  const si = sites.findIndex(s => s.id === siteId);
  if (si >= 0) { sites[si].status = 'listed'; DB.set('sites', sites); }

  closeModal('modal-list');
  toast(`"${site?.name}" listed for $${Number(price).toLocaleString()}!`, 'success');
  renderDashboard();
  renderListings();
  renderMarketplace();
}

function renderListings() {
  const listings = DB.get('listings');
  const el = document.getElementById('listingsTable');
  if (!listings.length) {
    el.innerHTML = `<div class="empty-state"><div class="icon">📋</div><h3>No listings</h3><p>List a site to start attracting buyers.</p><button class="btn btn-gold" onclick="openListSiteModal()">📋 Create Listing</button></div>`;
    return;
  }
  el.innerHTML = `<div class="card"><div class="table-wrap"><table>
    <thead><tr><th>Site</th><th>Category</th><th>Price</th><th>Revenue/mo</th><th>Traffic/mo</th><th>Tags</th><th>Listed</th><th>Actions</th></tr></thead>
    <tbody>${listings.map(l => `
      <tr>
        <td><b>${l.siteName}</b></td>
        <td><span class="badge badge-cyan">${l.category}</span></td>
        <td><b style="color:var(--gold)">$${l.price.toLocaleString()}</b></td>
        <td>${l.revenue ? '$'+l.revenue.toLocaleString() : '—'}</td>
        <td>${l.traffic ? l.traffic.toLocaleString() : '—'}</td>
        <td>${l.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</td>
        <td style="color:var(--muted)">${fmtDate(l.createdAt)}</td>
        <td><button class="btn btn-sm btn-danger" onclick="deleteListing('${l.id}')">Remove</button></td>
      </tr>`).join('')}
    </tbody></table></div></div>`;
}

function deleteListing(id) {
  if (!confirm('Remove this listing?')) return;
  DB.set('listings', DB.get('listings').filter(l => l.id !== id));
  renderListings();
  renderMarketplace();
  toast('Listing removed.', 'info');
}

// ============================================================
// MARKETPLACE
// ============================================================
function renderMarketplace() {
  const listings = DB.get('listings');
  const filter = document.getElementById('marketFilter')?.value || 'all';
  const filtered = filter === 'all' ? listings : listings.filter(l => l.category === filter);
  const el = document.getElementById('marketplaceGrid');
  if (!filtered.length) {
    el.innerHTML = `<div class="empty-state" style="grid-column:1/-1"><div class="icon">🏪</div><h3>No listings</h3><p>List your own sites for sale to populate the marketplace.</p><button class="btn btn-primary" onclick="openListSiteModal()">📋 List a Site</button></div>`;
    return;
  }
  el.innerHTML = filtered.map(l => `
    <div class="listing-card">
      <div class="listing-header">
        <div style="display:flex;justify-content:space-between;align-items:flex-start">
          <div>
            <div style="font-weight:700;font-size:15px;margin-bottom:4px">${l.siteName}</div>
            <span class="badge badge-cyan">${l.category}</span>
          </div>
          <div class="listing-price">$${l.price.toLocaleString()}</div>
        </div>
      </div>
      <div class="listing-body">
        <div class="listing-stats">
          <div class="listing-stat">
            <div class="listing-stat-val">${l.revenue ? '$'+l.revenue.toLocaleString() : '—'}</div>
            <div class="listing-stat-lbl">Monthly Revenue</div>
          </div>
          <div class="listing-stat">
            <div class="listing-stat-val">${l.traffic ? l.traffic.toLocaleString() : '—'}</div>
            <div class="listing-stat-lbl">Monthly Traffic</div>
          </div>
        </div>
        ${l.desc ? `<div style="font-size:12px;color:var(--muted);margin-bottom:12px">${l.desc}</div>` : ''}
        <div style="margin-bottom:12px">${l.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div>
        <div style="display:flex;gap:8px">
          <button class="btn btn-primary btn-sm" style="flex:1" onclick="contactSeller('${l.id}')">📩 Contact Seller</button>
          <button class="btn btn-secondary btn-sm" onclick="addLeadFromListing('${l.id}')">💾 Save</button>
        </div>
      </div>
    </div>
  `).join('');
}

function contactSeller(id) {
  toast('Opening contact form… (add your email in Settings)', 'info');
}

function addLeadFromListing(id) {
  const l = DB.get('listings').find(x => x.id === id);
  if (l) {
    document.getElementById('lead-interest').value = l.siteName;
    openModal('modal-lead');
  }
}

// ============================================================
// LEADS
// ============================================================
function openAddLeadModal() { openModal('modal-lead'); }

function submitLead() {
  const name = document.getElementById('lead-name').value.trim();
  const email = document.getElementById('lead-email').value.trim();
  if (!name) { toast('Please enter a name.', 'error'); return; }
  const lead = {
    id: Date.now().toString(),
    name, email,
    phone: document.getElementById('lead-phone').value,
    budget: document.getElementById('lead-budget').value,
    interest: document.getElementById('lead-interest').value,
    status: document.getElementById('lead-status').value,
    notes: document.getElementById('lead-notes').value,
    createdAt: new Date().toISOString()
  };
  const leads = DB.get('leads');
  leads.push(lead);
  DB.set('leads', leads);
  closeModal('modal-lead');
  toast('Lead saved!', 'success');
  renderLeads();
  renderDashboard();
  // clear
  ['lead-name','lead-email','lead-phone','lead-budget','lead-interest','lead-notes'].forEach(id => document.getElementById(id).value = '');
}

function renderLeads() {
  const leads = DB.get('leads');
  const tbody = document.getElementById('leadsTableBody');
  if (!leads.length) {
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--muted);padding:30px">No leads yet.</td></tr>';
    return;
  }
  const statusColors = { New:'badge-cyan', Contacted:'badge-purple', Interested:'badge-gold', Negotiating:'badge-green', Cold:'badge-red' };
  tbody.innerHTML = leads.map(l => `
    <tr>
      <td><b>${l.name}</b></td>
      <td style="font-family:var(--font-mono);font-size:11px">${l.email}</td>
      <td>${l.interest || '—'}</td>
      <td>${l.budget ? '<b style="color:var(--gold)">$'+Number(l.budget).toLocaleString()+'</b>' : '—'}</td>
      <td><span class="badge ${statusColors[l.status]||'badge-purple'}">${l.status}</span></td>
      <td style="color:var(--muted)">${fmtDate(l.createdAt)}</td>
      <td><button class="btn btn-sm btn-danger" onclick="deleteLead('${l.id}')">Remove</button></td>
    </tr>
  `).join('');
}

function deleteLead(id) {
  DB.set('leads', DB.get('leads').filter(l => l.id !== id));
  renderLeads();
  toast('Lead removed.', 'info');
}

// ============================================================
// DEALS
// ============================================================
function openAddDealModal() { openModal('modal-deal'); }

function submitDeal() {
  const site = document.getElementById('deal-site').value.trim();
  const buyer = document.getElementById('deal-buyer').value.trim();
  const amount = document.getElementById('deal-amount').value;
  if (!site || !buyer) { toast('Fill in site and buyer name.', 'error'); return; }
  const deal = {
    id: Date.now().toString(),
    site, buyer, amount: +amount,
    stage: document.getElementById('deal-stage').value,
    notes: document.getElementById('deal-notes').value,
    createdAt: new Date().toISOString()
  };
  const deals = DB.get('deals');
  deals.push(deal);
  DB.set('deals', deals);
  closeModal('modal-deal');
  toast('Deal saved!', 'success');
  renderDeals();
  renderDashboard();
}

function renderDeals() {
  const deals = DB.get('deals');
  ['negotiating','due-diligence','closed'].forEach(stage => {
    const col = document.getElementById('col-' + stage);
    const stagDeals = deals.filter(d => d.stage === stage);
    if (!stagDeals.length) {
      col.innerHTML = `<div style="font-size:12px;color:var(--muted);text-align:center;padding:20px;background:var(--surface);border:1px dashed var(--border);border-radius:8px">No deals</div>`;
      return;
    }
    col.innerHTML = stagDeals.map(d => `
      <div class="card" style="padding:14px;cursor:default">
        <div style="font-weight:700;margin-bottom:4px">${d.site}</div>
        <div style="font-size:12px;color:var(--muted);margin-bottom:8px">Buyer: ${d.buyer}</div>
        ${d.amount ? `<div style="color:var(--gold);font-weight:700;margin-bottom:8px">$${d.amount.toLocaleString()}</div>` : ''}
        ${d.notes ? `<div style="font-size:11px;color:var(--muted);margin-bottom:8px">${d.notes}</div>` : ''}
        <div style="display:flex;gap:6px">
          ${d.stage !== 'closed' ? `<button class="btn btn-sm btn-success" onclick="advanceDeal('${d.id}')">Advance →</button>` : '<span class="badge badge-green">✅ Closed</span>'}
          <button class="btn btn-sm btn-danger" onclick="deleteDeal('${d.id}')">🗑️</button>
        </div>
      </div>
    `).join('');
  });
}

function advanceDeal(id) {
  const deals = DB.get('deals');
  const i = deals.findIndex(d => d.id === id);
  const stages = ['negotiating','due-diligence','closed'];
  const ci = stages.indexOf(deals[i].stage);
  if (ci < stages.length - 1) { deals[i].stage = stages[ci + 1]; DB.set('deals', deals); renderDeals(); toast('Deal advanced!', 'success'); }
}

function deleteDeal(id) {
  DB.set('deals', DB.get('deals').filter(d => d.id !== id));
  renderDeals();
  toast('Deal removed.', 'info');
}

// ============================================================
// ANALYTICS
// ============================================================
function renderAnalytics() {
  const d = getData();
  document.getElementById('an-views').textContent = (d.sites.length * 247).toLocaleString();
  document.getElementById('an-rev').textContent = d.listings.reduce((s,l)=>s+(l.revenue||0),0) ? '$'+d.listings.reduce((s,l)=>s+(l.revenue||0),0).toLocaleString() : '—';
  document.getElementById('an-inq').textContent = d.leads.length;
  document.getElementById('an-deals').textContent = d.deals.filter(d=>d.stage==='closed').length;

  // Category breakdown
  const cats = {};
  d.sites.forEach(s => { cats[s.category] = (cats[s.category]||0)+1; });
  const total = d.sites.length || 1;
  const cb = document.getElementById('categoryBreakdown');
  if (!d.sites.length) { cb.innerHTML = '<div style="color:var(--muted);font-size:13px;text-align:center;padding:20px">Build some sites to see breakdown.</div>'; return; }
  cb.innerHTML = Object.entries(cats).map(([cat,count]) => `
    <div>
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:12px">${cat}</span>
        <span style="font-size:12px;color:var(--muted)">${count}</span>
      </div>
      <div class="progress-bar"><div class="progress-fill" style="width:${(count/total*100).toFixed(0)}%"></div></div>
    </div>
  `).join('');
}

// ============================================================
// DATA VAULT
// ============================================================
function renderVault() {
  const d = getData();
  document.getElementById('vault-sites').textContent = d.sites.length;
  document.getElementById('vault-listings').textContent = d.listings.length;
  document.getElementById('vault-leads').textContent = d.leads.length;
  document.getElementById('vault-deals').textContent = d.deals.length;
  renderVaultData();
}

function renderVaultData() {
  const key = document.getElementById('vaultTable').value;
  const data = DB.get(key);
  document.getElementById('vaultDataView').textContent = JSON.stringify(data, null, 2) || '[]';
}

function exportData() {
  const all = {
    sites: DB.get('sites'),
    listings: DB.get('listings'),
    leads: DB.get('leads'),
    deals: DB.get('deals'),
    settings: DB.getOne('settings'),
    exportedAt: new Date().toISOString()
  };
  const blob = new Blob([JSON.stringify(all, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'siteforge-backup-' + Date.now() + '.json';
  a.click();
  toast('Data exported!', 'success');
}

function importData() {
  const input = document.createElement('input');
  input.type = 'file';
  input.accept = '.json';
  input.onchange = e => {
    const file = e.target.files[0];
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        const data = JSON.parse(ev.target.result);
        if (data.sites) DB.set('sites', data.sites);
        if (data.listings) DB.set('listings', data.listings);
        if (data.leads) DB.set('leads', data.leads);
        if (data.deals) DB.set('deals', data.deals);
        if (data.settings) DB.setOne('settings', data.settings);
        renderVault();
        renderDashboard();
        toast('Data imported successfully!', 'success');
      } catch { toast('Invalid JSON file.', 'error'); }
    };
    reader.readAsText(file);
  };
  input.click();
}

function clearAllData() {
  if (!confirm('⚠️ This will permanently delete ALL your sites, listings, leads, and deals. This cannot be undone.\n\nAre you absolutely sure?')) return;
  ['sites','listings','leads','deals'].forEach(k => DB.set(k, []));
  renderDashboard();
  renderVault();
  toast('All data cleared.', 'info');
}

// ============================================================
// SETTINGS
// ============================================================
function loadSettings() {
  const s = DB.getOne('settings');
  document.getElementById('set-name').value = s.name || 'Xabdiel';
  document.getElementById('set-email').value = s.email || '';
  document.getElementById('set-biz').value = s.biz || 'The Original Granite & Cabinets';
  document.getElementById('set-bio').value = s.bio || '';
  document.getElementById('set-contact').value = s.contact || '';
  document.getElementById('set-payment').value = s.payment || '';
}

function saveSettings() {
  DB.setOne('settings', {
    name: document.getElementById('set-name').value,
    email: document.getElementById('set-email').value,
    biz: document.getElementById('set-biz').value,
    bio: document.getElementById('set-bio').value,
    contact: document.getElementById('set-contact').value,
    payment: document.getElementById('set-payment').value
  });
  toast('Settings saved!', 'success');
}

// ============================================================
// MODALS
// ============================================================
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); });
});

// ============================================================
// UTILS
// ============================================================
function fmtDate(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

function addActivity(text) {
  // Just a visual helper — dashboard reads from DB
}

